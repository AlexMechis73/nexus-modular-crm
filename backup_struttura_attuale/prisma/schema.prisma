// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// MODELLO DATI FASE 0: Autenticazione e Autorizzazione (RBAC)

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // Conterrà l'hash della password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relazione: un utente può avere più ruoli
  roles     UserRole[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // es. "Commerciale", "CMO"
  description String?

  // Relazioni
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // es. "view_own_leads", "view_all_deals"
  description String?

  // Relazione
  roles       RolePermission[]
}

// Tabelle "pivot" per le relazioni Many-to-Many

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}